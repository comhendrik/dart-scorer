pipeline {
    agent any

    environment {
        PATH = "/usr/local/bin:$PATH"
        REPO_URL = 'https://github.com/comhendrik/dart-scorer.git'
        APP_NAME = 'dart-scorer-frontend-only'
        DOCKER_IMAGE = "${APP_NAME}:latest"
    }

    stages {
        stage('Checkout Code') {
            steps {
                git url: "${REPO_URL}", branch: "main"
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    sh """
                    cd frontend-only
                    docker build -t ${DOCKER_IMAGE} .
                    """
                }
            }
        }

        stage('Setup Docker Image') {
            steps {
                script {
                    sh """
                    docker run --rm -d -p 8080:80 --name ${APP_NAME} ${DOCKER_IMAGE}
                    sleep 5
                    curl -f http://localhost:8080 || exit 1
                    """
                }
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deploy stage: Extend as needed for your environment.'
            }
        }
    }

    post {
        success {
            echo 'Pipeline completed successfully.'
        }
        failure {
            echo 'Pipeline failed.'
        }
    }
}
